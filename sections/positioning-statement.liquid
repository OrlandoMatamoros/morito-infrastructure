<style>
  .positioning-statement {
    background: linear-gradient(180deg, #3D2E28 0%, #4A3830 100%);
    text-align: center;
    padding: 90px 20px 80px;
  }

  .positioning-statement__ornament {
    display: block;
    width: 30px;
    height: 1px;
    background-color: #D68A59;
    border: none;
    margin: 0 auto 28px;
    opacity: 0.7;
  }

  .positioning-statement__headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 400;
    font-style: italic;
    color: #F2EDE8;
    margin: 0 auto;
    max-width: 780px;
    letter-spacing: 0.02em;
    line-height: 1.45;
  }

  .positioning-statement__divider {
    width: 40px;
    height: 1px;
    background-color: #D68A59;
    border: none;
    margin: 28px auto 0;
    opacity: 0.7;
  }

  .positioning-statement__subline {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    color: #F2EDE8;
    opacity: 0.5;
    margin: 0;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  @media screen and (max-width: 749px) {
    .positioning-statement {
      padding: 65px 24px 55px;
    }

    .positioning-statement__headline {
      font-size: 1.4rem;
      line-height: 1.5;
    }

    .positioning-statement__subline {
      font-size: 0.85rem;
    }
  }
</style>

<section class="positioning-statement">
  <span class="positioning-statement__ornament" aria-hidden="true"></span>
  <h2 class="positioning-statement__headline">{{ section.settings.headline | escape }}</h2>
  <hr class="positioning-statement__divider">
  {%- if section.settings.subline != blank -%}
    <p class="positioning-statement__subline">{{ section.settings.subline | escape }}</p>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Positioning Statement",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Cacao-Driven Confections"
    },
    {
      "type": "text",
      "id": "subline",
      "label": "Subline",
      "default": "Handcrafted in Brooklyn"
    }
  ],
  "presets": [
    {
      "name": "Positioning Statement"
    }
  ]
}
{% endschema %}
